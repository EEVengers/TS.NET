@namespace TS.NET.Sequences
@using TS.NET.Sequencer

@code {
    [Parameter]
    public required string Title { get; set; }
    [Parameter]
    public required ResultMetadataXYChart Chart { get; set; }
    [Parameter]
    public required string Image { get; set; }
    [Parameter]
    public double? ArrowX { get; set; }
    [Parameter]
    public double? ArrowY { get; set; }

    private List<(string Id, string Label)> GetButtons() => [("ok", "Ok"), ("cancel", "Cancel")];
}

<style>
    @((MarkupString)TrimStep.GetChartStyle())
</style>

<style>
    @((MarkupString)ModalUiStep.GetEmbeddedCss<Trim>())
</style>

<style>
    .trim-image-container {
        position: relative;
        display: inline-block;
    }

    .trim-image {
        display: block;
        height: 500px;
    }

    .trim-arrow-overlay {
        position: absolute;
        z-index: 2;
        transform: translateY(-50%);
        display: inline-flex;
        align-items: center;
        pointer-events: none;
    }

    .arrow {
        border: solid #59008c;
        border-width: 0 12px 12px 0;
        padding: 12px;
        transform: rotate(135deg);
        -webkit-transform: rotate(135deg);
    }
</style>

<div class="z-1 flex flex-col h-fit border border-zinc-600 bg-zinc-900 absolute inset-1/2 -translate-1/2" style="width:990px">
    <!-- Title bar -->
    <div class="flex-none flex flex-row items-center gap-2 p-2 pl-2 pr-2 bg-zinc-800">
        <div class="flex-none text-neutral-50 font-normal text-xs trim-box">@Title</div>
    </div>
    <div class="flex-none border-b border-zinc-600"></div>
    <!-- Content -->
    <div class="flex-auto flex flex-col p-3 overflow-y-auto">
        <div class="flex-auto flex flex-row gap-3 text-neutral-50">
            <div class="flex-auto">
                <div class="trim-image-container">
                    <img class="trim-image" src="@((MarkupString)ModalUiStep.GetEmbeddedPngDataUri<Trim>(@Image))" alt="" />
                    @if (ArrowX.HasValue && ArrowY.HasValue)
                    {
                        <div class="trim-arrow-overlay" style="@($"left:{ArrowX.Value}px;top:{ArrowY.Value}px;")">
                            <i class="arrow left"></i>
                        </div>
                    }
                </div>
            </div>
            <div class="flex-auto text-sm">
                @{
                var legendLocation = Chart.LegendLocation switch
                {
                    ResultMetadataXYChartLegendLocation.TopLeft => "top-left",
                    ResultMetadataXYChartLegendLocation.TopRight => "top-right",
                    ResultMetadataXYChartLegendLocation.BottomLeft => "bottom-left",
                    ResultMetadataXYChartLegendLocation.BottomRight => "bottom-right",
                    _ => "top-right"
                };
                <div>
                    <svg id="chart-1" width="700" height="500" style="color: black;"></svg>
                </div>
                }
            </div>
        </div>

        <div class="flex-none flex flex-row justify-end gap-2 mt-3">
        @foreach (var button in GetButtons())
        {
            <button id="modal-ui-@button.Id-button" type="button" class="border border-zinc-600 bg-zinc-600 p-3 text-neutral-50 font-normal text-sm w-20 h-11 inset-ring-2 inset-ring-zinc-800 active:inset-ring-zinc-500 hover:inset-ring-zinc-700 trim-box">
                @button.Label
            </button>
        }
        </div>
    </div>
</div>

<script>
    @foreach (var button in GetButtons())
    {
        <text>
        document.getElementById("modal-ui-@button.Id-button").addEventListener("mousedown", function () {
            var message = { command: "modal-ui-event", event: { "buttonClicked" : "@button.Id" } };
            window.external.sendMessage(JSON.stringify(message));
        });
        </text>
    }

    @((MarkupString)(TrimStep.GetChartJs()))
    
    new ResultMetadataXYChart("chart-1", {
        width: 700,
        height: 500,
        margin: { top: 40, right: 20, bottom: 60, left: 80},
        legendLocation: "@legendLocation"
    }).render(@((MarkupString)(Chart.ToJson())));
</script>